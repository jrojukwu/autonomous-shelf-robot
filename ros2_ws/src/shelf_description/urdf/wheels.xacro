<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="drive_wheel" params="name side_sign">

    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="robot_black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <xacro:wheel_inertial
        mass="${wheel_mass}"
        radius="${wheel_radius}"
        width="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin
        xyz="0 ${side_sign * wheel_separation / 2.0} ${-base_height / 2.0}"
        rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

  </xacro:macro>

  <xacro:drive_wheel name="left" side_sign="1"/>
  <xacro:drive_wheel name="right" side_sign="-1"/>

</robot>

