<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Mathematical constants -->

  <!-- Base dimensions -->
  <xacro:property name="base_length" value="0.70"/>
  <xacro:property name="base_width" value="0.50"/>
  <xacro:property name="base_height" value="0.20"/>

  <!-- Base ground clearance -->
  <xacro:property name="base_ground_clearance" value="0.10"/>

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_radius" value="0.10"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_separation" value="0.46"/>

  <!-- Caster dimensions -->
  <xacro:property name="caster_radius" value="0.04"/>

  <!-- Sensor placement -->
  <xacro:property name="lidar_height" value="0.28"/>
  <xacro:property name="camera_height" value="0.35"/>

  <!-- Approximate component masses -->
  <xacro:property name="base_mass" value="30.0"/>
  <xacro:property name="wheel_mass" value="2.0"/>
  <xacro:property name="caster_mass" value="0.5"/>

  <!-- Colors -->
  <material name="robot_blue">
    <color rgba="0.05 0.30 0.80 1.0"/>
  </material>

  <material name="robot_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <material name="robot_gray">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>

  <material name="sensor_red">
    <color rgba="0.80 0.05 0.05 1.0"/>
  </material>

  <!-- Inertial calculation for a rectangular box -->
  <xacro:macro name="box_inertial" params="mass x y z origin_xyz:='0 0 0'">
    <inertial>
      <origin xyz="${origin_xyz}" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (y*y + z*z) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (x*x + z*z) / 12.0}"
        iyz="0.0"
        izz="${mass * (x*x + y*y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <!-- Inertial calculation for a cylinder aligned with the Y axis -->
  <xacro:macro name="wheel_inertial" params="mass radius width">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (3*radius*radius + width*width) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * radius*radius / 2.0}"
        iyz="0.0"
        izz="${mass * (3*radius*radius + width*width) / 12.0}"/>
    </inertial>
  </xacro:macro>

</robot>

